<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>🩺 Botiquín Emocional</title>

<meta name="theme-color" content="#10b981">

<link rel="manifest" href="manifest.json">

<script src="https://cdn.tailwindcss.com"></script>


<style>

body{
font-family:Arial,sans-serif;
}


.card{

transition:.3s;

}


.card:hover{

transform:translateY(-6px);

}


.fade{

animation:fade .5s ease;

}


@keyframes fade{

from{

opacity:0;
transform:translateY(20px);

}


to{

opacity:1;
transform:translateY(0);

}

}


</style>


</head>



<body class="bg-slate-950 text-white min-h-screen">


<header class="p-6 text-center">


<h1 class="text-4xl font-bold text-emerald-400">

🩺 Botiquín Emocional

</h1>


<p class="text-slate-400 mt-3">

Primeros auxilios para el alma en momentos difíciles.

</p>


</header>




<main class="max-w-xl mx-auto p-5">



<section id="bienvenida"
class="mb-8">


<div class="bg-gradient-to-br from-emerald-900/50 to-slate-900 border border-emerald-500/30 rounded-3xl p-8 text-center shadow-xl">


<div class="text-5xl mb-4">

🩺

</div>


<h2 class="text-2xl font-bold mb-3">

Bienvenido al Botiquín Emocional

</h2>


<p class="text-slate-400 leading-relaxed mb-6">

No tienes que resolver toda tu vida hoy.

<br><br>

Solo identifica qué está pesando en tu corazón.

</p>


<button

onclick="comenzarBotiquin()"

class="bg-emerald-500 text-black font-bold px-8 py-3 rounded-xl hover:scale-105 transition">

Comenzar mi camino →

</button>


</div>


</section>





<section id="zona-emociones">


<h2 class="text-xl font-bold mb-2">

¿Cómo te sientes hoy?

</h2>



<div id="contador-uso"

class="mb-4 text-center text-sm text-emerald-400 font-bold">

</div>




<div class="grid grid-cols-2 gap-4">



<button onclick="mostrarEmocion('ansiedad')"

class="card bg-gradient-to-br from-blue-900 to-slate-900 border border-blue-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
🌀
</div>


<h3 class="font-bold text-lg mt-3">

Ansiedad

</h3>


<p class="text-xs text-slate-300 mt-2">

Mi mente no se detiene

</p>


</button>





<button onclick="mostrarEmocion('tristeza')"

class="card bg-gradient-to-br from-sky-900 to-slate-900 border border-sky-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
😢
</div>


<h3 class="font-bold text-lg mt-3">

Tristeza

</h3>


<p class="text-xs text-slate-300 mt-2">

Necesito consuelo

</p>


</button>





<button onclick="mostrarEmocion('enojo')"

class="card bg-gradient-to-br from-red-900 to-slate-900 border border-red-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
🔥
</div>


<h3 class="font-bold text-lg mt-3">

Enojo

</h3>


<p class="text-xs text-slate-300 mt-2">

Quiero recuperar mi calma

</p>


</button>





<button onclick="mostrarEmocion('soledad')"

class="card bg-gradient-to-br from-purple-900 to-slate-900 border border-purple-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
🌙
</div>


<h3 class="font-bold text-lg mt-3">

Soledad

</h3>


<p class="text-xs text-slate-300 mt-2">

Necesito sentir compañía

</p>


</button>




<button onclick="mostrarEmocion('agotamiento')"

class="card bg-gradient-to-br from-emerald-900 to-slate-900 border border-emerald-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
🪫
</div>


<h3 class="font-bold text-lg mt-3">

Agotamiento

</h3>


<p class="text-xs text-slate-300 mt-2">

Ya no puedo más

</p>


</button>




<button onclick="mostrarEmocion('desanimo')"

class="card bg-gradient-to-br from-amber-900 to-slate-900 border border-amber-700 rounded-3xl p-5 text-left shadow-xl">


<div class="text-4xl">
🍂
</div>


<h3 class="font-bold text-lg mt-3">

Desánimo

</h3>


<p class="text-xs text-slate-300 mt-2">

Necesito volver a levantarme

</p>


</button>



</div>


</section>





<section id="resultado"

class="mt-8 hidden">


<div class="fade bg-white text-slate-900 rounded-3xl p-6 shadow-xl">


<h2 id="titulo"

class="text-2xl font-bold text-emerald-700">

</h2>




<p id="mensaje"

class="mt-4 text-lg leading-relaxed">

</p>




<div class="mt-6 p-4 bg-emerald-50 rounded-xl">


<p class="font-bold text-emerald-700">

🌱 Pequeña acción:

</p>


<p id="accion"

class="mt-2">

</p>


</div>




<button onclick="nuevaReceta()"

class="mt-6 w-full bg-emerald-500 text-black font-bold py-3 rounded-xl hover:bg-emerald-400 transition">


Otra reflexión


</button>



</div>


</section>





</main>




<footer class="text-center text-xs text-slate-600 p-8">


Creado para acompañar momentos difíciles ❤️

<br>

Botiquín Emocional © 2026


</footer>





<script>


const recetas = {


ansiedad:[


{

titulo:"Cuando tu mente corre demasiado 🌀",

mensaje:"No todo pensamiento merece una respuesta. A veces la mente crea tormentas donde solo existe una nube. Hoy no tienes que resolver toda tu vida, solo este momento.",

accion:"Respira profundo 5 veces y pregúntate: ¿Qué puedo controlar ahora?"

},


{

titulo:"El silencio también es medicina 🌿",

mensaje:"Tu valor no depende de tener todo bajo control. Hay batallas que se ganan descansando y confiando.",

accion:"Apaga las notificaciones durante 10 minutos y regálate tranquilidad."

}


],




tristeza:[


{

titulo:"Tus lágrimas también hablan ❤️",

mensaje:"La tristeza no significa debilidad. A veces el corazón necesita detenerse para sanar.",

accion:"Escribe una cosa por la que todavía puedes agradecer hoy."

},


{

titulo:"Después de la noche llega la mañana 🌅",

mensaje:"Los momentos difíciles no escriben toda tu historia. Son solamente una página de un libro mucho más grande.",

accion:"Busca una pequeña cosa que te dé esperanza hoy."

}


],




enojo:[


{

titulo:"No entregues tu paz al enojo 🔥",

mensaje:"Una reacción de segundos puede crear heridas que tardan años en sanar. Tu fuerza está en elegir cómo responder.",

accion:"Antes de responder, espera 10 segundos y respira."

},


{

titulo:"La calma también es poder",

mensaje:"Controlar tus emociones no significa ignorarlas; significa que ellas no controlan tu destino.",

accion:"Aléjate unos minutos antes de tomar una decisión."

}


],




soledad:[


{

titulo:"Nunca estás completamente solo 🌙",

mensaje:"Hay temporadas donde el silencio pesa, pero incluso esos momentos pueden convertirse en espacios para encontrarte contigo mismo.",

accion:"Envía un mensaje a alguien que aprecias o busca una conversación sincera."

},


{

titulo:"Tu presencia tiene valor",

mensaje:"Aunque hoy sientas distancia de otros, tu vida sigue teniendo propósito y significado.",

accion:"Haz algo pequeño que cuide de ti hoy."

}


],



agotamiento:[

{

titulo:"Tu cansancio también merece descanso 🪫",

mensaje:"No naciste para cargar el mundo entero sobre tus hombros. A veces la verdadera fuerza está en detenerse, respirar y recuperar energía.",

accion:"Toma unos minutos de silencio, respira profundo y permite que tu mente descanse."

},


{

titulo:"No tienes que ser fuerte todo el tiempo",

mensaje:"Incluso los árboles necesitan estaciones donde parecen detenerse. Tu vida también tiene momentos para recuperar fuerzas.",

accion:"Haz una cosa pequeña hoy solo para cuidar de ti."

}

],




desanimo:[

{

titulo:"Este momento no define tu historia 🍂",

mensaje:"Un día difícil no significa una vida perdida. A veces las etapas más oscuras preparan cambios que todavía no puedes ver.",

accion:"Escribe una pequeña victoria que hayas logrado, aunque parezca sencilla."

},


{

titulo:"Vuelve a empezar una vez más",

mensaje:"Caer no elimina tu camino recorrido. Cada intento demuestra que todavía existe esperanza dentro de ti.",

accion:"Da un pequeño paso hoy, aunque sea solamente uno."

}

]



};





let emocionActual = "";





function comenzarBotiquin(){


const bienvenida = document.getElementById("bienvenida");


bienvenida.style.opacity="0";


setTimeout(()=>{


bienvenida.style.display="none";


},500);


}





function mostrarEmocion(tipo){



emocionActual = tipo;



const lista = recetas[tipo];



const receta = lista[

Math.floor(Math.random()*lista.length)

];



document.getElementById("resultado")

.classList.remove("hidden");



document.getElementById("titulo").innerHTML =

receta.titulo;



document.getElementById("mensaje").innerHTML =

receta.mensaje;



document.getElementById("accion").innerHTML =

receta.accion;




window.scrollTo({

top:document.body.scrollHeight,

behavior:"smooth"

});


}





function nuevaReceta(){


if(emocionActual){


mostrarEmocion(emocionActual);


}


}


// =============================
// SISTEMA PREMIUM
// =============================


const LIMITE_GRATIS = 10;


let consultas = 
parseInt(localStorage.getItem("consultas_botiquin")) || 0;



let premium =
localStorage.getItem("botiquin_premium") === "true";





function actualizarContador(){


const caja =
document.getElementById("contador-uso");



if(!caja) return;



if(premium){


caja.innerHTML =
"🌟 Usuario Premium - Acceso ilimitado";


return;


}



let restantes =
LIMITE_GRATIS - consultas;



caja.innerHTML =

`🩺 Te quedan ${restantes} reflexiones gratuitas`;



}





const mostrarOriginal = mostrarEmocion;



mostrarEmocion = function(tipo){



if(!premium && consultas >= LIMITE_GRATIS){


mostrarPremium();


return;


}



if(!premium){


consultas++;


localStorage.setItem(
"consultas_botiquin",
consultas
);


}



mostrarOriginal(tipo);



actualizarContador();



};






function mostrarPremium(){



document.getElementById("resultado")

.classList.remove("hidden");



document.getElementById("titulo").innerHTML =

"🌟 Botiquín Premium";



document.getElementById("mensaje").innerHTML =

"Has utilizado tus 10 reflexiones gratuitas. Desbloquea acceso ilimitado para seguir recibiendo acompañamiento diario.";



document.getElementById("accion").innerHTML =

`

<button

onclick="activarPremium()"

class="w-full bg-emerald-500 text-black font-bold py-3 rounded-xl">

Desbloquear Premium

</button>

`;



}





function activarPremium(){



localStorage.setItem(

"botiquin_premium",

"true"

);



premium=true;



actualizarContador();



alert(

"🌟 Premium activado"

);



}





// =============================
// IDIOMA
// =============================



function cambiarIdioma(idioma){



const titulo =
document.querySelector("header h1");



const subtitulo =
document.querySelector("header p");




if(idioma==="en"){



titulo.innerHTML =
"🩺 Emotional First Aid";



subtitulo.innerHTML =
"Emotional support for difficult moments.";



}

else{



titulo.innerHTML =
"🩺 Botiquín Emocional";



subtitulo.innerHTML =
"Primeros auxilios para el alma en momentos difíciles.";



}



}





// =============================
// SELECTOR DE IDIOMA
// =============================


</script>




<div class="fixed top-4 right-4">


<select

class="bg-slate-900 border border-slate-700 rounded-xl p-2 text-sm"

onchange="cambiarIdioma(this.value)">



<option value="es">

🇪🇸 Español

</option>



<option value="en">

🇺🇸 English

</option>



</select>


</div>






<script>


actualizarContador();





// =============================
// SERVICE WORKER
// =============================


if("serviceWorker" in navigator){



window.addEventListener(

"load",

()=>{


navigator.serviceWorker


.register("/sw.js")


.then(()=>{


console.log(

"Botiquín Emocional funcionando offline"

);


})


.catch(error=>{


console.log(

"Error Service Worker:",
error

);


});



}


);


}



</script>



</body>

</html>
